# ==========================================
# Настройки Telegram-бота
# ==========================================
# Токен бота, полученный от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ID администраторов Telegram (через запятую)
ADMIN_IDS=1703779981

# Telegram-username техподдержки в боте
SUPPORT_USERNAME=@mrzkysupbot


# ==========================================
# Настройки Базы Данных & Redis
# ==========================================
# Режим базы данных: "sqlite" или "postgresql"
DATABASE_MODE=postgresql
SQLITE_PATH=./data/bot.db

# Настройки PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ultra_vpn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_here

# URL для подключения к Redis (FSM-состояния и кэш)
REDIS_URL=redis://localhost:6379/0


# ==========================================
# Интеграция с панелью 3x-ui
# ==========================================
# Полный URL к вашей API-панели 3x-ui
XUI_API_URL=https://your_panel_domain.com:port/base_path

# Тип авторизации: "api_key" или "basic_auth"
XUI_AUTH_TYPE=api_key

# Bearer Токен (если XUI_AUTH_TYPE=api_key)
XUI_API_KEY=your_3xui_api_key_token_here

# Логин и Пароль (если XUI_AUTH_TYPE=basic_auth)
XUI_USERNAME=admin
XUI_PASSWORD=password


# ==========================================
# Настройки Платежных Шлюзов
# ==========================================
# Включение/Выключение YooKassa (в тестовом режиме по умолчанию)
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=your_yookassa_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret_key

# Включение/Выключение CryptoBot (в тестовой сети Testnet по умолчанию)
CRYPTOBOT_ENABLED=false
CRYPTOBOT_API_TOKEN=your_cryptobot_token
CRYPTOBOT_TESTNET=true

# Включение/Выключение Telegram Stars (встроенная валюта Telegram)
TELEGRAM_STARS_ENABLED=true

# Включение/Выключение RollyPay
ROLLYPAY_ENABLED=false
ROLLYPAY_API_KEY=your_rollypay_api_key
ROLLYPAY_SIGNING_SECRET=your_rollypay_signing_secret
ROLLYPAY_TERMINAL_ID=your_rollypay_terminal_id


# ==========================================
# Настройки Веб-Сервера
# ==========================================
# Хост и порт для запуска FastAPI сервера
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Публичный адрес вашего сервера (используется для генерации ссылок оплаты и вебхуков)
WEB_URL=https://vpn.yourdomain.com

# Данные для входа в панель администратора (Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password_here

# Интервал синхронизации трафика планировщиком (в секундах)
SYNC_INTERVAL_SECONDS=3600
